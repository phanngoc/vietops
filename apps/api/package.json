{
  "name": "@vietops/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/jwt": "^9.0.2",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/websocket": "^11.0.2",
    "@prisma/client": "^6.4.1",
    "@vietops/shared": "*",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.34.8",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.13.4",
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "typescript-eslint": "^8.24.1",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.6"
  }
}

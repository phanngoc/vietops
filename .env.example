# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vietops

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=900
REFRESH_TOKEN_EXPIRES_IN=604800

# Google SSO
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@vietops.io

# Slack
SLACK_WEBHOOK_URL=

# Jira OAuth App
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:3000/integrations/jira/callback

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NODE_ENV=development
